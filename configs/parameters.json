{
        "hgb": {
            "learning_rate": 0.03,
            "max_iter": 600,
            "l2_regularization": 0.05,
            "early_stopping": true
        },
        
        "rf": {
            "n_estimators": 1200,
            "max_features": "sqrt",
            "min_samples_leaf": 2,
            "n_jobs": -1
        },

        "lr": {
            "solver": "lbfgs",
            "C": 1.0,
            "max_iter": 3000
        },

        "svc": {
            "kernel": "rbf",
            "C": 3.0,
            "gamma": "scale",
            "probability": true
        },

        "torch_mlp": {
            "hidden_layers": [256, 128, 64],
            "dropout": 0.2,
            "epochs": 200,
            "batch_size": 64,
            "learning_rate": 1e-3,
            "weight_decay": 1e-4,
            "device": "auto",
            "verbose": false
        },

        "torch_ft_transformer": {
            "d_model": 64,
            "n_heads": 8,
            "n_layers": 4,
            "ff_dim": 256,
            "dropout": 0.2,
            "epochs": 50,
            "batch_size": 128,
            "learning_rate": 2e-4,
            "weight_decay": 1e-4,
            "device": "auto",
            "verbose": false
        }
    }